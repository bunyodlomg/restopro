# ─── MongoDB ───────────────────────────────────
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/restopro
# Local MongoDB:  mongodb://localhost:27017/restopro
MONGO_URI=mongodb://localhost:27017/restopro

# ─── JWT ────────────────────────────────────────
# Murakkab va uzun string kiriting (kamida 32 belgi)
JWT_SECRET=restopro_super_secret_key_2025_change_this

# ─── Server ─────────────────────────────────────
PORT=5000

# ─── CORS ───────────────────────────────────────
# Frontend manzili (vergul bilan ajratib bir nechta kiritish mumkin)
CLIENT_URL=http://localhost:5173
